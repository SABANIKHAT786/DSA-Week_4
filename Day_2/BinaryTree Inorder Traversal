class Solution {
    List<Integer> list = new ArrayList<>();
    public List<Integer> inorderTraversal(TreeNode root) {
     inorder(root);
     return list;
    }
    private List<Integer> inorder(TreeNode root){
        if(root == null){
            return null;
        }
        inorder(root.left);
        list.add(root.val);
        inorder(root.right);

        return list;
    }
}
